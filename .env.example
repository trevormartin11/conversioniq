# ============================================================================
# CIQ Hub — Environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# The app runs in MOCK mode (rich seed data, no external calls) until the
# relevant keys below are present, so you can preview everything before wiring
# anything up. Each block is independent — fill in what you have.
# ============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the deployed app (used for webhook + magic-link callbacks).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- App login (gates the whole dashboard) ----------------------------------
# Shared team password + a random secret for the signed auth cookie. When
# AUTH_SECRET is set, every page requires sign-in at /login. Leave AUTH_SECRET
# empty in local dev to browse without a login.
APP_PASSWORD=
AUTH_SECRET=

# --- Hub database (Supabase) -------------------------------------------------
# A DEDICATED Supabase project — NOT the Health OS project (off-limits).
# When these are set the app reads/writes Postgres; when absent it uses in-memory
# seed data so the UI is fully browsable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI (Anthropic Claude) ---------------------------------------------------
# Powers reply classification, draft replies and copy suggestions.
# Without it the app falls back to deterministic, rules-based drafts.
ANTHROPIC_API_KEY=
# Premium model for generative work (strategy, copy, drafting, personalization).
ANTHROPIC_MODEL=claude-opus-4-8
# Cheap/fast model for the high-frequency reply classifier (runs every 10 min).
# This is the main per-token cost lever — keep it on a small model.
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
# Soft monthly alert line (USD) for the live Claude-spend meter on Costs (not a hard cap).
AI_SOFT_BUDGET_USD=50
# ACTUAL billed cost (not estimate) on the Costs meter. Separate ADMIN key (sk-ant-admin...),
# created by an org owner under Anthropic Console → Settings → Admin keys. Org-scoped.
ANTHROPIC_ADMIN_API_KEY=
# Optional: scope actual cost to JUST this app. Run this app's API key in its own Anthropic
# workspace and put that workspace id here (wrkspc_...); otherwise the meter shows the whole org.
ANTHROPIC_WORKSPACE_ID=

# --- Instantly.ai (sending + replies + inbox health) -------------------------
# v2 API. Header: Authorization: Bearer <key>. Base: https://api.instantly.ai/api/v2
INSTANTLY_API_KEY=
# Optional shared secret used to verify inbound Instantly webhooks.
INSTANTLY_WEBHOOK_SECRET=

# --- Twilio (consent-gated SMS channel) --------------------------------------
# Powers real SMS sends on /channels. Until all three (SID, token, sender) are set,
# SMS sends SIMULATE — the consent + daily-cap gate still applies either way.
# Account SID + Auth Token: Twilio Console → Account Info.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The sender. Use a Messaging Service SID (recommended for A2P 10DLC — Twilio picks
# the number and applies your registered campaign) OR a single From number in E.164.
# If the SID is set it takes precedence over the From number.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

# --- Zoho CRM v6 (canonical leads + Do-Not-Contact) --------------------------
# OAuth refresh-token flow. Access tokens are minted hourly from the refresh token.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_DOMAIN=https://www.zohoapis.com

# --- ConversionIQ's Zoho org (partner side: demo->deal handoff + outcome loop) -
# A SEPARATE Zoho org with its own OAuth app. On demo booked we create a Deal here;
# its outcome (won/lost) flows back to train sourcing. ZOHO_CIQ_DEMO_STAGE = the
# pipeline stage a freshly booked demo lands in.
ZOHO_CIQ_CLIENT_ID=
ZOHO_CIQ_CLIENT_SECRET=
ZOHO_CIQ_REFRESH_TOKEN=
ZOHO_CIQ_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_CIQ_API_DOMAIN=https://www.zohoapis.com
ZOHO_CIQ_DEMO_STAGE=Demo Scheduled
ZOHO_CIQ_WON_STAGE=Closed Won
ZOHO_CIQ_LOST_STAGE=Closed Lost
# Shared secret for CIQ's Zoho workflow -> our outcome webhook (x-webhook-secret header or ?secret=).
CIQ_ZOHO_WEBHOOK_SECRET=

# --- Namecheap (DNS for the sending domains: DMARC/SPF auto-fix) -------------
# API access must be enabled in Namecheap + the calling server IP whitelisted.
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=

# --- Apollo (data) — TWO keys, kept strictly separate ------------------------
# Personal key = search + enrich (free to use).
APOLLO_PERSONAL_API_KEY=
# CIQ key = paid credits. HARD RULE: never auto-spend. Every spend is gated +
# confirmed + logged. Kept in a separate var so it can never be used by accident.
APOLLO_CIQ_API_KEY=

# --- Personalization signals (Phase 2) ---------------------------------------
# Google reviews + recent news come from Outscraper (OUTSCRAPER_API_KEY) and only
# fire when it's connected. Social/LinkedIn activity is a pluggable provider:
# set both to light it up. POSTs { domain, company }; expects { signal } or
# { summary } or { posts: [{ text }] }. Off by default → no cost, never faked.
SOCIAL_SIGNAL_API_URL=
SOCIAL_SIGNAL_API_KEY=

# --- Gmail (reply fallback + exports) ----------------------------------------
# Service/OAuth credentials for reading reply inboxes if not pulled via Instantly.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Telegram (alerts: hot replies + daily digest) ---------------------------
# Create a bot via @BotFather to get the token; start a chat with it to get the
# chat id. See docs/SETUP.md for the 3-step walkthrough.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
